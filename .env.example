# Familien-Kochbuch — Environment variable template.
# Copy to `.env` and fill in real values before `docker compose up`.
# Everything here is read by docker-compose.yml's ${VAR:-default} expansions.

# ── Initial Admin user (seeded on first boot if no users exist) ───────
# Override before the first boot. If left unset docker-compose falls back
# to development defaults and the API logs a loud warning.
ADMIN_EMAIL=admin@familien-kochbuch.local
ADMIN_PASSWORD=ChangeMe!Admin2026

# ── JWT signing ────────────────────────────────────────────────────────
# HMAC-SHA256 key. Must be at least 32 characters (256 bits). Rotate
# invalidates all outstanding access tokens; refresh tokens survive.
# Generate locally: `openssl rand -base64 48`
JWT_SIGNING_KEY=dev-only-signing-key-replace-via-JWT_SIGNING_KEY-env-var

# ── Frontend base URL (used in invite + password-reset links) ─────────
APP_FRONTEND_BASE_URL=http://localhost

# ── Recipe photo storage (SeaweedFS S3 gateway) ────────────────────────
# Keep the *_ACCESS_KEY / *_SECRET_KEY in sync with infra/seaweedfs/s3.json
# if you change either here — SeaweedFS validates against that file.
PHOTO_STORAGE_ENDPOINT=http://seaweedfs:8333
PHOTO_STORAGE_BUCKET=recipe-photos
PHOTO_STORAGE_ACCESS_KEY=familien-kochbuch
PHOTO_STORAGE_SECRET_KEY=familien-kochbuch
PHOTO_STORAGE_PUBLIC_BASE_URL=http://localhost/photos
