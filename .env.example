# Familien-Kochbuch — Environment variable template.
# Copy to `.env` and fill in real values before `docker compose up`.
# Everything here is read by docker-compose.yml's ${VAR:-default} expansions.

# ── Initial Admin user (seeded on first boot if no users exist) ───────
# Override before the first boot. If left unset docker-compose falls back
# to development defaults and the API logs a loud warning.
# ADMIN_DISPLAY_NAME shows up next to "zuletzt geändert" — set it to a
# real person's name (e.g. a first name), not the role label, otherwise
# the revision history reads as if the role itself were the author.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=CHANGE_ME_admin_password
ADMIN_DISPLAY_NAME=Familienkoch

# ── Postgres (prod only; docker-compose.yml has dev defaults) ──────────
# Generate with: openssl rand -base64 24
POSTGRES_DB=familien_kochbuch
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_postgres_password

# ── JWT + photo-URL signing ────────────────────────────────────────────
# HMAC-SHA256 key. Must be at least 32 characters (256 bits). Rotation
# invalidates all outstanding access tokens AND invalidates every
# previously-issued signed photo URL (photo URLs derive their key as
# SHA256("img-sign:" + this value)). Refresh tokens survive.
# Generate locally: `openssl rand -base64 48`
JWT_SIGNING_KEY=CHANGE_ME_replace_with_openssl_rand_base64_48

# ── Frontend base URL (used in invite + password-reset links) ─────────
APP_FRONTEND_BASE_URL=http://localhost

# ── SeaweedFS filer (recipe photos) ────────────────────────────────────
# Plain-HTTP REST endpoint on the internal docker network. SeaweedFS is
# NOT exposed to the host — the backend proxies every photo read through
# /api/photos/{**path} with a signed URL.
SEAWEEDFS_FILER_URL=http://seaweedfs:8333

# Signed photo URLs expire after this many hours (decimals allowed).
# Lower briefly (e.g. 0.0001) to exercise the 403-on-expired path.
IMAGES_SIGNATURE_VALIDITY_HOURS=2

# ── Azure OpenAI (Phase 2 — video/photo recipe extraction + AI chat) ───
# Only read by the Python extractor microservice. The .NET API reads
# AzureOpenAI__* mirrors (see below). Leave empty to boot without AI —
# the stack still runs, just without the AI-powered import/chat surfaces.
#
# Endpoint is the resource root (no trailing path). The Python client
# appends /openai/responses?api-version=... per call.
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
# Responses API version pinned for reproducibility. Bump only when the
# extractor service has been tested against a newer preview.
AZURE_OPENAI_API_VERSION=2025-04-01-preview
#
# Deployment names must match what was provisioned in the Azure resource.
# Typical model picks:
#   gpt-4.1-mini for recipe extraction (cost/quality sweet spot, strong
#   structured-output behaviour) and gpt-5.1-chat for the in-app AI chat
#   (conversational-tuned).
# Rename to your actual deployment names if they differ from the model id.
AZURE_OPENAI_DEPLOYMENT_STRUCTURING=gpt-4.1-mini
AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-5.1-chat

# CR2 — .NET chat endpoint reads AzureOpenAI__* keys. Same values as the
# Python extractor; docker-compose maps the _CHAT / _STRUCTURING names
# above onto AzureOpenAI__ChatDeployment + AzureOpenAI__Deployment on
# the api container. Leave the chat deployment blank to fall back to
# the structuring deployment (reuses one Azure resource).
# AzureOpenAI__Endpoint=$AZURE_OPENAI_ENDPOINT
# AzureOpenAI__ApiKey=$AZURE_OPENAI_API_KEY
# AzureOpenAI__ApiVersion=$AZURE_OPENAI_API_VERSION
# AzureOpenAI__Deployment=$AZURE_OPENAI_DEPLOYMENT_STRUCTURING
# AzureOpenAI__ChatDeployment=$AZURE_OPENAI_DEPLOYMENT_CHAT

# ── Python extractor service-to-service auth (Phase 2, P2-6 onward) ────
# HMAC shared secret used to sign requests from the .NET API to the
# Python extractor. .NET signs "{user_id}:{timestamp}:{body-hash}" with
# this key, the extractor verifies. Generate locally:
#   openssl rand -base64 48
# In development docker-compose falls back to a placeholder ("dev-only-
# shared-secret") so the stack boots without this set, but production
# MUST override — see docker-compose.prod.yml which requires it non-empty.
EXTRACTOR_SHARED_SECRET=

# Override to point the .NET API at a different extractor host. The
# default is the internal docker hostname "http://python-extractor:8000"
# and works out of the box for docker-compose. Leave unset unless you
# run the extractor on a separate host or port.
# PYTHON_EXTRACTOR_BASE_URL=http://python-extractor:8000

# PV2 progress-callback SSRF allowlist (host-only, no scheme/port).
# The Python extractor's ``ExtractUrlRequest.callback_url`` +
# ``ExtractPhotosRequest.callback_url`` pydantic validator rejects any
# URL whose host does not match this value (422 at request parse).
# The default "api" matches the docker-compose service name, so the
# stack boots without setting this. Override only when the .NET API
# runs on a different hostname (e.g. host-run dev, or a prod deploy
# that renamed the service).
# PROGRESS_CALLBACK_HOST=api

# Max gleichzeitige Hangfire-Worker (Concurrency-Cap für Extraktions-Jobs).
# Default 2 passt zum VPS-Budget (8 GB / 6 CPU für python-extractor).
# HANGFIRE_WORKERS=2

# ── SMTP — password-reset + app-invite + group-invite emails (PF3) ─────
# Leave these empty to fall back to the NoOpEmailSender (dev logger-only)
# — reset + invite links will appear in the api container logs. Populate
# for production (Posteo / Migadu / any provider with SMTP submission on
# 587 + STARTTLS). docker-compose.yml passes these through as
# Smtp__Host / Smtp__Port / ... onto the .NET api container.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDRESS=
SMTP_FROM_NAME=Familien-Kochbuch
