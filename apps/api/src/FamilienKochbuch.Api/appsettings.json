{
  "ConnectionStrings": {
    "Postgres": "Host=postgres;Database=familien_kochbuch;Username=app;Password=dev",
    "Redis": "redis:6379"
  },
  "Jwt": {
    "SigningKey": "CHANGE_ME_IN_ENV_JWT_SIGNING_KEY_MUST_BE_AT_LEAST_32_CHARS",
    "Issuer": "familien-kochbuch",
    "Audience": "familien-kochbuch-web",
    "AccessTokenLifetimeMinutes": 15,
    "RefreshTokenLifetimeDays": 30
  },
  "App": {
    "FrontendBaseUrl": "http://localhost"
  },
  "SeaweedFS": {
    "FilerUrl": "http://seaweedfs:8333"
  },
  "Images": {
    "SignatureValidityHours": 2
  },
  "PythonExtractor": {
    "BaseUrl": "http://python-extractor:8000",
    "SharedSecret": "dev-only-shared-secret"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  },
  "AllowedHosts": "*"
}
