# Dev reverse-proxy sitting in front of the compose stack.
# Single entry at http://localhost that routes /api/* to the .NET API,
# everything else to the React SPA container. Recipe photos are served
# by the backend itself via /api/photos/{**path} (signed URLs) — the
# SeaweedFS filer is never reachable from outside the docker network.
:80 {
    encode zstd gzip

    # PV1 — /api/internal/* is reserved for intra-container callbacks
    # (e.g. the Python extractor posting progress updates on the docker
    # bridge). External callers must not even learn the route exists;
    # respond 404 before the reverse_proxy block so the request never
    # hits Kestrel. The app-level InternalOnlyMiddleware layers a second
    # defence for direct-to-container access (not port-mapped in compose,
    # but protected anyway).
    @internal path /api/internal/*
    handle @internal {
        respond 404
    }

    handle /api/* {
        reverse_proxy api:5000
    }

    handle {
        reverse_proxy web:5173
    }
}
