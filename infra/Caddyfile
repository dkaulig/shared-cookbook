# Dev reverse-proxy sitting in front of the compose stack.
# Single entry at http://localhost that routes /api/* to the .NET API,
# everything else to the React SPA container.
:80 {
    encode zstd gzip

    handle /api/* {
        reverse_proxy api:5000
    }

    # Recipe photos live in SeaweedFS's S3 gateway; stream them through the
    # same origin so CORS + CSP stay simple and the API can return absolute
    # URLs pinned to this host.
    handle /photos/* {
        uri strip_prefix /photos
        reverse_proxy seaweedfs:8333
    }

    handle {
        reverse_proxy web:5173
    }
}
